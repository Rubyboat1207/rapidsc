// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug rapidsc",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "make",
      "args": ["build", "compile_example"],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "$ZED_WORKTREE_ROOT/build/linux/rapidsc",
    "args": ["$ZED_WORKTREE_ROOT/build/linux/example.rpdb"],
    "cwd": "$ZED_WORKTREE_ROOT"
  }
]
